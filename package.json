{
  "name": "amigurumi-nest",
  "version": "1.0.0",
  "description": "Scalable Node.js e-commerce backend (Express + Sequelize + MySQL) with authentication system, session-based shopping cart, order processing, REST API, admin features, and full test coverage including unit, integration, and E2E tests.",
  "main": "app.js",
  "scripts": {
    "test": "jest --forceExit --detectOpenHandles",
    "test:unit": "jest tests/unit --forceExit",
    "test:integration": "jest tests/integration --forceExit",
    "test:e2e": "jest tests/e2e --forceExit --testTimeout=30000",
    "test:coverage": "jest --coverage --forceExit",
    "test:ui": "playwright test",
    "test:ui:dev": "playwright test --ui",
    "start": "node app.js",
    "dev": "nodemon app.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.18.2",
    "helmet": "^8.1.0",
    "leo-profanity": "^1.9.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.15.3",
    "nodemailer": "^8.0.5",
    "redis": "^5.12.1",
    "sequelize": "^6.37.7",
    "swagger-ui-express": "^5.0.1",
    "validator": "^13.15.35"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/jest": "^29.5.8",
    "jest": "^29.7.0",
    "jest-mock-extended": "^3.0.5",
    "nodemon": "3.1.7",
    "puppeteer": "^21.6.1",
    "redis-mock": "^0.56.3",
    "supertest": "^6.3.3"
  }
}
