<%- include('admin/layout_start', { title: 'Комментарии', currentUser, activeSection: 'comments' }) %>

<div class="admin-header mb-4">
  <h1><i class="bi bi-chat-left-text"></i> Комментарии</h1>
  <p>Модерация и управление отзывами покупателей</p>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="card shadow-sm border-0 h-100">
      <div class="card-body">
        <div class="text-muted small mb-1">Всего в списке</div>
        <div class="h4 mb-0"><%= stats.total %></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card shadow-sm border-0 h-100">
      <div class="card-body">
        <div class="text-muted small mb-1">Одобрено</div>
        <div class="h4 mb-0"><%= stats.approvedCount %></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card shadow-sm border-0 h-100">
      <div class="card-body">
        <div class="text-muted small mb-1">Скрыто</div>
        <div class="h4 mb-0"><%= stats.hiddenCount %></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card shadow-sm border-0 h-100">
      <div class="card-body">
        <div class="text-muted small mb-1">Удалено</div>
        <div class="h4 mb-0"><%= stats.deletedCount %></div>
      </div>
    </div>
  </div>
</div>

<div class="card shadow-sm border-0 mb-4">
  <div class="card-body">
    <form method="get" action="/admin/comments" class="row g-3 align-items-end">
      <div class="col-md-4">
        <label class="form-label">Поиск</label>
        <input type="search" name="q" value="<%= filters.q %>" class="form-control" placeholder="Текст, автор или email">
      </div>
      <div class="col-md-2">
        <label class="form-label">Статус</label>
        <select name="status" class="form-select">
          <option value="all" <%= filters.status === 'all' ? 'selected' : '' %>>Все</option>
          <option value="approved" <%= filters.status === 'approved' ? 'selected' : '' %>>Одобренные</option>
          <option value="hidden" <%= filters.status === 'hidden' ? 'selected' : '' %>>Скрытые</option>
          <option value="blocked" <%= filters.status === 'blocked' ? 'selected' : '' %>>Заблокированные</option>
          <option value="deleted" <%= filters.status === 'deleted' ? 'selected' : '' %>>Удалённые</option>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label">Сортировка</label>
        <select name="sort" class="form-select">
          <option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Сначала новые</option>
          <option value="oldest" <%= filters.sort === 'oldest' ? 'selected' : '' %>>Сначала старые</option>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label">Товар</label>
        <select name="productId" class="form-select">
          <option value="">Все товары</option>
          <% products.forEach((product) => { %>
            <option value="<%= product.id %>" <%= String(filters.productId) === String(product.id) ? 'selected' : '' %>><%= product.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2 d-flex gap-2">
        <button class="btn btn-primary flex-grow-1">Фильтр</button>
        <a href="/admin/comments" class="btn btn-outline-secondary">Сброс</a>
      </div>
    </form>
  </div>
</div>

<% if (!comments || comments.length === 0) { %>
  <div class="alert alert-info">Комментариев по текущему фильтру нет.</div>
<% } else { %>
  <div class="d-flex flex-column gap-3">
    <% comments.forEach((comment) => { %>
      <div class="card shadow-sm border-0">
        <div class="card-body">
          <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-3">
            <div>
              <div class="fw-semibold"><%= comment.author.name %></div>
              <div class="text-muted small">
                <%= comment.author.email || ('User #' + comment.author.id) %>
              </div>
            </div>

            <div class="text-lg-end">
              <span class="badge <%= comment.statusClass %> text-uppercase mb-2"><%= comment.statusLabel %></span>
              <div class="small text-muted"><%= comment.createdAtFormatted %></div>
            </div>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-5">
              <div class="small text-muted mb-1">Товар</div>
              <a href="/product/<%= comment.product.id %>" class="fw-semibold text-decoration-none"><%= comment.product.name %></a>
              <div class="small">
                <a href="/product/<%= comment.product.id %>" class="text-primary text-decoration-none">Открыть товар</a>
              </div>
            </div>
            <div class="col-md-7">
              <div class="small text-muted mb-1">Комментарий</div>
              <div class="border rounded-3 p-3 bg-light text-break"><%= comment.text %></div>
              <% if (comment.status === 'blocked' && comment.blockedReason) { %>
                <div class="small text-muted mt-2">Причина блокировки: <%= comment.blockedReason %></div>
              <% } %>
            </div>
          </div>

          <div class="row g-3 align-items-stretch">
            <% if (comment.status === 'approved') { %>
              <div class="col-md-8">
                <div class="small text-muted mb-1">Ответ магазина</div>

                <% if (comment.hasReply) { %>
                  <div class="border rounded-3 p-3 mb-2 text-break"><%= comment.adminReply %></div>
                  <div class="small text-success">Ответ есть</div>
                <% } else { %>
                  <div class="border rounded-3 p-3 mb-2 text-muted">Ответа пока нет</div>
                <% } %>

                <form method="POST" action="/admin/comments/<%= comment.id %>/reply" class="mt-3">
                  <input type="hidden" name="returnTo" value="<%= returnTo %>">
                  <label class="form-label">Ответ</label>
                  <textarea name="adminReply" class="form-control mb-2" rows="3" placeholder="Ответ магазина..." required><%= comment.adminReply %></textarea>
                  <button class="btn btn-dark btn-sm">Сохранить ответ</button>
                </form>
              </div>
            <% } else { %>
              <div class="col-md-8">
                <div class="border rounded-3 p-3 bg-light h-100 d-flex align-items-center text-muted">
                  Ответ магазина скрыт для этого статуса
                </div>
              </div>
            <% } %>

            <div class="col-md-4">
              <div class="h-100 border-start-md ps-md-3">
                <div class="small text-muted mb-2">Действия</div>

                <% if (comment.status === 'deleted') { %>
                  <div class="d-grid gap-2">
                    <form method="POST" action="/admin/comments/<%= comment.id %>/restore">
                      <input type="hidden" name="returnTo" value="<%= returnTo %>">
                      <button class="btn btn-outline-success w-100">Restore</button>
                    </form>
                  </div>
                <% } else if (comment.status === 'approved') { %>
                  <div class="d-grid gap-2">
                    <form method="POST" action="/admin/comments/<%= comment.id %>/hide">
                      <input type="hidden" name="returnTo" value="<%= returnTo %>">
                      <button class="btn btn-outline-secondary w-100">Скрыть</button>
                    </form>

                    <form method="POST"
                          action="/admin/comments/<%= comment.id %>/delete"
                          data-confirm
                          data-confirm-title="Удалить комментарий?"
                          data-confirm-description="Комментарий будет скрыт через soft-delete. Это действие нельзя отменить."
                          data-confirm-text="Удалить"
                          data-confirm-cancel-text="Отмена">
                      <input type="hidden" name="returnTo" value="<%= returnTo %>">
                      <button class="btn btn-outline-danger w-100">Удалить</button>
                    </form>
                  </div>
                <% } else { %>
                  <div class="d-grid gap-2">
                    <form method="POST" action="/admin/comments/<%= comment.id %>/approve">
                      <input type="hidden" name="returnTo" value="<%= returnTo %>">
                      <button class="btn btn-outline-success w-100">Одобрить</button>
                    </form>

                    <form method="POST"
                          action="/admin/comments/<%= comment.id %>/delete"
                          data-confirm
                          data-confirm-title="Удалить комментарий?"
                          data-confirm-description="Комментарий будет скрыт через soft-delete. Это действие нельзя отменить."
                          data-confirm-text="Удалить"
                          data-confirm-cancel-text="Отмена">
                      <input type="hidden" name="returnTo" value="<%= returnTo %>">
                      <button class="btn btn-outline-danger w-100">Удалить</button>
                    </form>
                  </div>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<%- include('admin/layout_end', { activeSection }) %>