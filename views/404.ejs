<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title><%= title || '404 - Страница не найдена' %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link href="/css/main.css" rel="stylesheet" />
  </head>
  <body class="error-page">
    <main class="error-page-wrap">
      <section class="error-page-card text-center">
        <div class="error-page-emoji" aria-hidden="true">
            <img src="/img/logo.png" alt="Amigurumi Nest">
        </div>
        
        <% if (sessionExpired) { %>
          <!-- Режим: Сессия истекла -->
          <div class="error-page-code fw-bold">⏱️</div>
          <h1 class="error-page-title h2">Сессия завершена</h1>
          <p class="error-page-subtitle">
            Ваша сессия истекла. Войдите снова, чтобы продолжить работу.
          </p>
          <div class="error-page-actions">
            <a class="btn btn-primary btn-lg" href="/login">
              <i class="bi bi-box-arrow-in-right me-2"></i>Войти снова
            </a>
          </div>
        <% } else { %>
          <!-- Режим: Обычный 404 -->
          <div class="error-page-code fw-bold">404</div>
          <h1 class="error-page-title h2">Страница не найдена</h1>
          <p class="error-page-subtitle">
            Кажется, ты заблудился. Эта страница не существует или была перемещена.
          </p>
          <div class="error-page-actions">
            <a class="btn btn-primary btn-lg" href="/">
              <i class="bi bi-house-door me-2"></i>Вернуться на главную
            </a>
          </div>
        <% } %>
      </section>
    </main>
  </body>
</html>
