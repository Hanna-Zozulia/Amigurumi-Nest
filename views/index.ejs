<%- include('partials/header', { title: 'Amigurumi Nest' }) %>

<div class="container">

  <!-- Блок 1 -->
  <div class="row block">
    <div class="col-md-6 h1">
      <h1>Amigurumi Nest — это мир мягких вязаных чудес.</h1>
    </div>

    <div class="col-md-6 h2">
      <div class="vertical-slider">
        <div class="slider-track">

          <% (products || []).slice(0, 3).forEach(function(product) { %>
            <div class="toys-item">
              <img src="<%= product.image %>" alt="<%= product.name %>">
            </div>
          <% }) %>

        </div>
      </div>
    </div>
  </div>

  <!-- Блок 2 (оставляем как есть, это контент) -->
  <div class="row block_2">
    <div class="col-md-6 h2">
      <h2>Почему выбирают наши игрушки?</h2>
    </div>

    <div class="col-md-6 block_ul">
      <ul>
        <li>Каждая игрушка уникальная и сделана с любовью.</li>
        <li>Мы используем безопасные материалы.</li>
        <li>Создают уют и тепло.</li>
        <li>Подходят для подарков.</li>
      </ul>
    </div>
  </div>

  <!-- Блок 3 = реальные продукты -->
  <div class="row block_3">
    <h2>Тренды сейчас</h2>

    <div class="block_3 toy-row">

      <% (products || []).forEach(function(product) { %>
        <div class="toy-item">
          <img src="<%= product.image %>" class="img-fluid mb-2">
          <p><%= product.name %></p>
        </div>
      <% }) %>

    </div>
  </div>

  <% if (reviews.length > 0) { %>

    <div class="row block_4">
      <h2>Ваши отзывы</h2>

      <div class="reviews-grid">

        <% reviews.forEach(review => { %>
          <div class="review-item">
            <h4><strong><%= review.User.name %></strong></h4>
            <p><%= review.text %></p>
            <p class="date">
              <%= new Date(review.createdAt).getFullYear() %>
            </p>
          </div>
        <% }) %>

      </div>
    </div>

<% } %>

</div>

<%- include('partials/footer') %>