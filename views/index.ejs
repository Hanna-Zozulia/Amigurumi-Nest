<%- include('partials/header', { title: 'Amigurumi Nest' }) %>
  <div class="container">

    <!-- Block 1 -->
      <div class="row block">
        <div class="col-md-6 h1">
          <h1>Amigurumi Nest — это мир мягких вязаных чудес.</h1>
        </div>

        <div class="col-md-6 h2">
          <div class="vertical-slider">
            <div class="slider-track">

              <%# Server-side: render slider items by iterating over `products` by index %>
              <% for (let i = 0; i < (products || []).length; i += 1) { %>
                <div class="toys-item">
                  <a href="/product/<%= products[i].id %>">
                    <img src="<%= normalizeImagePath(products[i].image) %>" alt="<%= products[i].name %>">
                  </a>
                </div>
              <% } %>

            </div>
          </div>
        </div>
      </div>

  <!-- Block 2 -->
    <div class="row block_2">
      <div class="col-md-6 h2">
        <h2>Почему выбирают наши игрушки?</h2>
      </div>

      <div class="col-md-6 block_ul">
        <ul>
          <li>Каждая игрушка уникальная и сделана с любовью.</li>
          <li>Мы используем безопасные материалы.</li>
          <li>Создают уют и тепло.</li>
          <li>Подходят для подарков.</li>
        </ul>
      </div>
    </div>

  <!-- Block 3 -->
    <div class="row block_3">
        <h2>Тренды сейчас</h2>

        <div class="block_3 toy-row">
          
          <%# Server-side: render product cards for the "Trends" section %>
          <% (products || []).forEach(function(product) { %>
            
            <div class="toy-item">
              <a href="/product/<%= product.id %>">
                <img src="<%= normalizeImagePath(product.image) %>" class="img-fluid mb-2">
                <p><%= product.name %></p>
              </a>
            </div>
            
          <% }) %>

        </div>
      </div>

  <% if (reviews.length > 0) { %>

    <div class="row block_4">
      <h2>Ваши отзывы</h2>

      <div class="reviews-grid">

        <%# Server-side: render list of recent reviews provided in `reviews` %>
        <% reviews.forEach(review => { %>
          <div class="review-item">
            <h4><strong><%= review.User.name %></strong></h4>
            <p><%= review.text %></p>
            <p class="date">
               <%= new Intl.DateTimeFormat('ru-RU', {
                  day: '2-digit',
                  month: '2-digit',
                  year: 'numeric'
                }).format(new Date(review.createdAt)) %>
            </p>
          </div>
        <% }) %>

      </div>
    </div>

<% } %>

</div>

<%- include('partials/footer') %>