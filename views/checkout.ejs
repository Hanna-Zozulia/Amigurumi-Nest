<%- include('partials/header', { title: 'Оформление заказа', currentUser: currentUser }) %>

<div class="container mt-5">
  <h1 class="mb-4">Оформление заказа</h1>

  <% if (successMessage) { %>
    <div class="alert alert-success" role="alert">
      <%= successMessage %>
    </div>
  <% } %>

  <!-- ТОВАРЫ ИЗ КОРЗИНЫ -->
  <div class="mb-4">
    <h4>Ваш заказ:</h4>

    <% if (cart && cart.items && cart.items.length > 0) { %>

      <div class="border rounded p-3">

        <% cart.items.forEach(item => { %>
          <div class="d-flex justify-content-between mb-2">
            <div>
              <b><%= item.Product.name %></b>
              <div class="text-muted small">
                Кол-во: <%= item.quantity %>
              </div>
            </div>

            <div>
              <%= item.Product.price * item.quantity %> €
            </div>
          </div>
        <% }) %>

      </div>

      <div class="mt-3 text-end">
        <h5>Итого: <b><%= total %> €</b></h5>
      </div>
      
    <% } else { %>
      <p class="text-muted">Корзина пустая</p>
    <% } %>
  </div>

  <!-- ФОРМА -->
  <form method="POST" action="/order">

    <div class="mb-3">
      <label class="form-label">Имя и фамилия</label>
      <input type="text" name="name" class="form-control" required>
    </div>

    <div class="mb-3">
      <label class="form-label">Email</label>
      <input type="email" name="email" class="form-control" required>
    </div>

    <div class="mb-3">
      <label class="form-label">Телефон</label>
      <input type="text" name="phone" class="form-control" required>
    </div>

    <div class="mb-3">
      <label class="form-label">Комментарий</label>
      <textarea name="notes" class="form-control" rows="3"></textarea>
    </div>

    <button class="btn btn-success w-100" data-loading data-loading-text="Оформляем заказ...">
      Оформить заказ
    </button>

    <a href="/catalog" class="btn btn-link w-100 mt-2">
      ← Вернуться к покупкам
    </a>

  </form>

</div>

<%- include('partials/footer') %>