<%- include('admin/layout_start', { title: 'Заказы', currentUser, activeSection: 'orders' }) %>

<div class="admin-header">
  <h1><i class="bi bi-box-seam"></i> Заказы</h1>
  <p>Управление и отслеживание заказов — всего <%= orders.length %></p>
</div>

<% if (!orders || orders.length === 0) { %>
  <div class="alert alert-info">Пока нет оформленных заказов.</div>
<% } else { %>
  <div class="card shadow-sm border-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0 admin-orders-table">
        <thead class="table-light">
          <tr>
            <th>#</th>
            <th>Клиент</th>
            <th>Телефон</th>
            <th>Дата</th>
            <th>Статус</th>
            <th>Сумма</th>
            <th class="text-end">Действия</th>
          </tr>
        </thead>
        <tbody>
          <%# Server-side: render admin orders table rows from `orders` %>
          <% orders.forEach(order => { %>
            <tr>
              <td data-label="#"><strong>#<%= order.id %></strong></td>
              <td data-label="Клиент"><%= order.customerName %></td>
              <td data-label="Телефон"><%= order.customerPhone %></td>
              <td data-label="Дата"><small><%= order.createdAtFormatted %></small></td>
              <td data-label="Статус">
                <span class="badge <%= order.status === 'unprocessed' ? 'bg-secondary' : order.status === 'processing' ? 'bg-warning text-dark' : 'bg-success' %>">
                  <%= order.statusLabel %>
                </span>
              </td>
              <td data-label="Сумма"><strong><%= order.total.toFixed(2) %> EUR</strong></td>
              <td data-label="Действия" class="text-end">
                <div class="d-flex justify-content-end gap-2 admin-order-actions">
                  <a href="/admin/orders/<%= order.id %>" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-eye"></i> Открыть
                  </a>
                  <form method="post" action="/admin/orders/<%= order.id %>/status" class="d-inline">
                    <input type="hidden" name="redirectTo" value="list">
                    <button class="btn btn-sm btn-outline-dark" data-loading data-loading-text="...">
                      <i class="bi bi-arrow-right"></i> Далее
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>

<%- include('admin/layout_end', { activeSection: 'orders' }) %>
