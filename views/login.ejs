<%- include('partials/header', { title: type === 'login' ? 'Вход' : 'Регистрация' }) %>

<div class="row justify-content-center login-container">
  <div class="col-sm-10 col-md-6 col-lg-4 mb-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <h1 class="h4 mb-3 text-center"><%= type === 'login' ? 'Вход' : 'Регистрация' %></h1>

        <% if (showError) { %>
          <div class="alert alert-danger" role="alert">
            <% if (type === 'register' && errorCode === 'password') { %>
              Пароль слишком слабый. Используйте минимум 8 символов, заглавную и строчную буквы, цифру и спецсимвол.
            <% } else if (type === 'register' && errorCode === 'mismatch') { %>
              Пароли не совпадают.
            <% } else if (type === 'register' && errorCode === 'exists') { %>
              Пользователь с таким email уже существует.
            <% } else { %>
              Ошибка авторизации или регистрации. Проверьте данные и попробуйте снова.
            <% } %>
          </div>
        <% } %>

        <% if (typeof resetSuccess !== 'undefined' && resetSuccess) { %>
          <div class="alert alert-success" role="alert">
            Пароль обновлен. Теперь войдите с новым паролем.
          </div>
        <% } %>

        <% if(type === 'login'){ %>
          <!-- Форма входа -->
          <form action="/login" method="post">
            <div class="mb-3">
              <label for="email" class="form-label">Email</label>
              <input type="email" class="form-control" id="email" name="email" required />
            </div>
            <div class="mb-3">
              <label for="password" class="form-label">Пароль</label>
              <input type="password" class="form-control" id="password" name="password" required />
            </div>
            <div class="mb-3 text-end">
              <a href="/forgot-password" class="small">Забыли пароль?</a>
            </div>
            <button type="submit" class="btn btn-primary w-100" data-loading data-loading-text="Входим...">Вход</button>
          </form>
          <p class="text-center mt-3">
            <a href="/register">Нет аккаунта? Зарегистрироваться</a>
          </p>
        <% } else { %>
          <!-- Форма регистрации -->
          <form action="/register" method="post">
            <div class="mb-3">
              <label for="name" class="form-label">Имя</label>
              <input type="text" class="form-control" id="name" name="name" required />
            </div>
            <div class="mb-3">
              <label for="email-register" class="form-label">Email</label>
              <input type="email" class="form-control" id="email-register" name="email" required />
            </div>
            <div class="mb-3">
              <label for="password-register" class="form-label">Пароль</label>
              <input type="password" class="form-control" id="password-register" name="password" minlength="8" autocomplete="new-password" required />
              <div class="form-text">Минимум 8 символов, 1 заглавная буква, 1 строчная буква, 1 цифра и 1 спецсимвол.</div>
            </div>
            <div class="mb-3">
              <label for="confirm-password" class="form-label">Подтвердить пароль</label>
              <input type="password" class="form-control" id="confirm-password" name="confirm_password" minlength="8" autocomplete="new-password" required />
            </div>
            <button type="submit" class="btn btn-success w-100" data-loading data-loading-text="Создаем аккаунт...">Зарегистрироваться</button>
          </form>
          <p class="text-center mt-3">
            <a href="/login">Уже есть аккаунт? Войти</a>
          </p>
        <% } %>

      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>