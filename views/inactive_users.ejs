<%- include('admin/layout_start', { title: 'Пользователи', currentUser, activeSection: 'users' }) %>

<div class="admin-header">
  <h1><i class="bi bi-people-fill"></i> Пользователи</h1>
  <p>Управление пользователями и их статусами — всего <%= users.length %></p>
</div>

<% if (updated) { %>
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="bi bi-check-circle-fill"></i> Статус пользователя успешно обновлен.
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<% if (error) { %>
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="bi bi-exclamation-triangle-fill"></i> Не удалось обновить статус пользователя.
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>

<% if (!users || users.length === 0) { %>
  <div class="alert alert-info">Пользователи не найдены.</div>
<% } else { %>
  <div class="card shadow-sm border-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th class="admin-user-col-id">ID</th>
            <th>Имя</th>
            <th>Email</th>
            <th>Дата регистрации</th>
            <th>Последний вход</th>
            <th class="admin-user-col-status">Статус</th>
            <th class="text-end">Действие</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(user => { %>
            <tr>
              <td><small>#<%= user.id %></small></td>
              <td><strong><%= user.name %></strong></td>
              <td><small><%= user.email %></small></td>
              <td><small><%= user.createdAtFormatted %></small></td>
              <td><small><%= user.lastLoginAtFormatted || '—' %></small></td>
              <td>
                <% if (user.status === 'active') { %>
                  <span class="badge bg-success">active</span>
                <% } else if (user.status === 'inactive') { %>
                  <span class="badge bg-warning text-dark">inactive</span>
                <% } else { %>
                  <span class="badge bg-secondary"><%= user.status %></span>
                <% } %>
              </td>
              <td class="text-end">
                <form method="post" action="/admin/users/<%= user.id %>/status" class="d-flex gap-2 justify-content-end">
                  <select name="status" class="form-select form-select-sm admin-user-status-select">
                    <% allowedStatuses.forEach(status => { %>
                      <option value="<%= status %>" <%= user.status === status ? 'selected' : '' %>>
                        <%= status %>
                      </option>
                    <% }) %>
                  </select>
                  <button class="btn btn-sm btn-primary" type="submit" data-loading data-loading-text="...">
                    Сохранить
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>

<%- include('admin/layout_end', { activeSection: 'users' }) %>

<%- include('partials/footer') %>
