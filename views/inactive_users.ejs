<%- include('partials/header', { title: 'Пользователи', currentUser: currentUser }) %>

<div class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 m-0">Управление пользователями</h1>
    <a href="/catalog" class="btn btn-outline-secondary btn-sm">Назад</a>
  </div>

  <% if (updated) { %>
    <div class="alert alert-success" role="alert">
      Статус пользователя успешно обновлен.
    </div>
  <% } %>

  <% if (error) { %>
    <div class="alert alert-danger" role="alert">
      Не удалось обновить статус пользователя.
    </div>
  <% } %>

  <% if (!users || users.length === 0) { %>
    <div class="alert alert-info" role="alert">
      Пользователи не найдены.
    </div>
  <% } else { %>
    <div class="table-responsive">
      <table class="table table-hover align-middle shadow-sm">
        <thead class="table-light">
          <tr>
            <th>ID</th>
            <th>Имя</th>
            <th>Email</th>
            <th>Дата регистрации</th>
            <th>Последний вход</th>
            <th>Статус</th>
            <th class="text-end">Действие</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(user => { %>
            <tr>
              <td><%= user.id %></td>
              <td><%= user.name %></td>
              <td><%= user.email %></td>
              <td><%= user.createdAtFormatted %></td>
              <td>
                <%= user.lastLoginAtFormatted %>
              </td>
              <td>
                <% if (user.status === 'active') { %>
                  <span class="badge bg-success">active</span>
                <% } else if (user.status === 'inactive') { %>
                  <span class="badge bg-warning text-dark">inactive</span>
                <% } else { %>
                  <span class="badge bg-secondary"><%= user.status %></span>
                <% } %>
              </td>
              <td class="text-end">
                <form method="post" action="/admin/users/<%= user.id %>/status" class="d-inline-flex gap-2">
                  <select name="status" class="form-select form-select-sm" style="min-width: 130px;">
                    <% allowedStatuses.forEach(status => { %>
                      <option value="<%= status %>" <%= user.status === status ? 'selected' : '' %>>
                        <%= status %>
                      </option>
                    <% }) %>
                  </select>

                  <button class="btn btn-sm btn-primary" type="submit" data-loading data-loading-text="Сохраняем...">
                    Сохранить
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
