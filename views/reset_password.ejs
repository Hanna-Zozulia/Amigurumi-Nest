<%- include('partials/header', { title: 'Сброс пароля' }) %>

<div class="row justify-content-center login-container">
  <div class="col-sm-10 col-md-6 col-lg-5 mb-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <h1 class="h4 mb-3 text-center">Сброс пароля</h1>

        <% if (invalidToken) { %>
          <div class="alert alert-warning" role="alert">
            Ссылка для сброса пароля недействительна или срок ее действия истек.
          </div>
          <p class="text-center mb-0">
            <a href="/forgot-password">Запросить новую ссылку</a>
          </p>
        <% } else { %>

          <% if (showError) { %>
            <div class="alert alert-danger" role="alert">
              Проверьте пароль: минимум 6 символов и совпадение с подтверждением.
            </div>
          <% } %>

          <form action="/reset-password/<%= encodeURIComponent(token) %>" method="post">
            <div class="mb-3">
              <label for="password" class="form-label">Новый пароль</label>
              <input type="password" class="form-control" id="password" name="password" minlength="6" required />
            </div>

            <div class="mb-3">
              <label for="confirm_password" class="form-label">Подтвердите новый пароль</label>
              <input type="password" class="form-control" id="confirm_password" name="confirm_password" minlength="6" required />
            </div>

            <button type="submit" class="btn btn-success w-100" data-loading data-loading-text="Сохраняем пароль...">
              Сохранить новый пароль
            </button>
          </form>

          <p class="text-center mt-3 mb-0">
            <a href="/login">Вернуться ко входу</a>
          </p>
        <% } %>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
