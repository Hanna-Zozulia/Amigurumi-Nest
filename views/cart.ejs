<%- include('partials/header', { title: 'Корзина' }) %>

<div class="container mt-5 cart-page">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 m-0">Ваша корзина</h1>
    <a href="/catalog" class="btn btn-link mt-3 no-underline">
      ← Вернуться к покупкам
    </a>
  </div>

  <% if (typeof cart === 'undefined' || !cart || !cart.items || cart.items.length === 0) { %>
  <div class="alert alert-info text-center">
    Корзина пуста
  </div>
  <% } else { %>
  <div class="table-responsive cart-table-wrap">
    <table class="table table-hover align-middle shadow-sm cart-items-table">
      <thead class="table-light">
        <tr>
          <th>Товар</th>
          <th>Цена</th>
          <th>Кол-во</th>
          <th>Сумма</th>
        </tr>
      </thead>
      <tbody>
        <%# Server-side: iterate over `cart.items` and render each table row %>
        <% cart.items.forEach(item => { %>
        <tr>
          <td data-label="Товар">
            <div class="d-flex align-items-center">
              <% if (item.Product) { %>
              <img src="<%= normalizeImagePath(item.Product.image) %>" alt="<%= item.Product.name %>" class="me-2 rounded cart-product-image">
              <span class="order_name"><%= item.Product.name %></span>
              <% } else { %>
                <span class="text-muted">Товар недоступен</span>
                <% } %>
            </div>
          </td>
          <td data-label="Цена">
            <% if (item.Product) { %>
                <%= Number(item.Product.price).toFixed(2) %> €
            <% } else { %>
                -
            <% } %>
          </td>
          <td data-label="Кол-во">
            <div class="d-flex align-items-center">
              <form method="POST" action="/cart/remove">
                <button class="btn btn-sm btn-outline-secondary cart-quantity-button">-</button>
                <input type="hidden" name="productId" value="<%= item.productId %>">
              </form>

              <span class="px-2 fw-bold text-center cart-quantity-count"><%= item.quantity %></span>

              <form method="POST" action="/cart/add" class="ms-1">
                <button class="btn btn-sm btn-outline-secondary cart-quantity-button">+</button>
                <input type="hidden" name="productId" value="<%= item.productId %>">
              </form>
            </div>
          </td>
          <td data-label="Сумма">
            <% if (item.Product) { %>
              <%= Number(item.Product.price * item.quantity).toFixed(2) %> €
            <% } else { %>
              -
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
      <tfoot class="fw-bold cart-totals">
        <tr>
          <td colspan="3" class="text-end">Итого:</td>
          <td>
            <%= cart.items.reduce((sum, item) => sum + (item.Product ? item.Product.price * item.quantity : 0), 0).toFixed(2) %> €</td>
        </tr>
      </tfoot>
    </table>
  </div>

  <div class="d-flex justify-content-between mt-3 cart-actions">
    <form method="POST"
          action="/cart/clear"
          data-confirm
          data-confirm-title="Очистить корзину?"
          data-confirm-description="Все товары будут удалены из корзины. Это действие нельзя отменить."
          data-confirm-text="Очистить"
          data-confirm-cancel-text="Отмена">
      <button class="btn btn-danger cart-clear-btn">Очистить корзину</button>
    </form>
    <a href="/checkout" class="btn btn-success">Оформить заказ</a>
  </div>
 
<% } %>
</div>

<%- include('partials/footer') %>

