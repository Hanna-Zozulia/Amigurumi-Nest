<%- include('partials/header', { title: 'Корзина' }) %>

<div class="container mt-5">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 m-0">Ваша корзина</h1>
    <a href="/catalog" class="btn btn-outline-primary btn-sm">Вернуться к покупкам</a>
  </div>

  <% if (!cart || !cart.items || cart.items.length === 0) { %>
  <div class="alert alert-info text-center">
    Корзина пуста
  </div>
  <% } else { %>
  
  <div class="table-responsive">
    <table class="table table-hover align-middle shadow-sm">
      <thead class="table-light">
        <tr>
          <th>Товар</th>
          <th>Цена</th>
          <th>Кол-во</th>
          <th>Сумма</th>
        </tr>
      </thead>
      <tbody>
        <% cart.items.forEach(item => { %>
        <tr>
          <td>
            <div class="d-flex align-items-center">
              <% if (item.Product) { %>
              <img src="<%= item.Product.pic %>" alt="<%= item.Product.name %>" style="width:60px; height:60px; object-fit:cover;" class="me-2 rounded">
              <span><%= item.Product.name %></span>
              <% } else { %>
                <span class="text-muted">Товар недоступен</span>
                <% } %>
            </div>
          </td>
          <td>
            <% if (item.Product) { %>
                <%= Number(item.Product.price).toFixed(2) %> €
            <% } else { %>
                -
            <% } %>
            </td>
          <td>
            <div class="d-flex align-items-center">
              <form method="POST" action="/cart/remove" class="me-1">
                <button class="btn btn-sm btn-danger" style="width:30px; padding:0;">-</button>
                <input type="hidden" name="productId" value="<%= item.productId %>">
              </form>

              <span class="px-2 fw-bold text-center" style="min-width:30px;"><%= item.quantity %></span>

              <form method="POST" action="/cart/add" class="ms-1">
                <button class="btn btn-sm btn-success" style="width:30px; padding:0;">+</button>
                <input type="hidden" name="productId" value="<%= item.productId %>">
              </form>
            </div>
          </td>
          <td>
            <% if (item.Product) { %>
              <%= Number(item.Product.price * item.quantity).toFixed(2) %> €
            <% } else { %>
              -
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
      <tfoot class="table-light fw-bold">
        <tr>
          <td colspan="3" class="text-end">Итого:</td>
          <td>
            <%= cart.items.reduce((sum, item) => sum + (item.Product ? item.Product.price * item.quantity : 0), 0).toFixed(2) %> €</td>
        </tr>
      </tfoot>
    </table>
  </div>

  <div class="d-flex justify-content-between mt-3">
    <form method="POST" action="/cart/clear">
      <button class="btn btn-danger">Очистить корзину</button>
    </form>
    <a href="/checkout" class="btn btn-success">Оформить заказ</a>
  </div>
 
<% } %>
</div>

<%- include('partials/footer') %>

