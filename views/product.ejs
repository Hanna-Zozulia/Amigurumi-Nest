<%- include('partials/header', { title: product.name, currentUser: currentUser }) %>

<div class="container mt-5">

  <div class="row">

    <!-- Картинка -->
    <div class="col-md-6">
      <img src="<%= product.image %>" class="img-fluid rounded shadow-sm" alt="<%= product.name %>">
    </div>

    <!-- Информация -->
    <div class="col-md-6">
      <h2><%= product.name %></h2>

      <p class="text-muted">
        <b>Категория:</b> <%= product.category %>
      </p>

      <p><%= product.desc %></p>

      <h4 class="mt-3">Цена: <%= product.price %> €</h4>

      <div class="mt-4">
        <div class="d-flex justify-content-end">
          <button class="btn btn-primary">Купить</button>
        </div>
          <% if (currentUser && currentUser.role === 'admin') { %>
            <button class="btn btn-outline-primary">Edit</button>
            <button class="btn btn-outline-danger">Delete</button>
          <% } %>
      </div>

      <% if (currentUser) { %>
        <h4>Оставить отзыв</h4>

        <form method="POST" action="/review/add">
          <input type="hidden" name="productId" value="<%= product.id %>">

          <div class="mb-3">
            <textarea name="text" class="form-control" rows="3" placeholder="Ваш отзыв..." required></textarea>
          </div>
          <div class="d-flex justify-content-end">
            <button class="btn btn-success">Отправить</button>
          </div>
        </form>

      <% } else { %>

        <hr>
        <p class="text-muted">
          Чтобы оставить отзыв, <a href="/login">войдите</a> в аккаунт.
        </p>

      <% } %>
      <div class="d-flex justify-content-end">
        <a href="/catalog" class="btn btn-link mt-3">← Назад в каталог</a>
      </div>
    </div>

      <h4 class="product_h4">Отзывы</h4>

      <% if (product.Reviews && product.Reviews.length > 0) { %>

        <div class="d-flex flex-column gap-3">

        <% product.Reviews.forEach(review => { %>
          <div class="border rounded p-3 shadow-sm d-flex justify-content-between align-items-start">
            <div class="w-100 me-3">
              <b class="d-block"><%= review.User.name %></b>
              <p id="text-<%= review.id %>" class="mb-1"><%= review.text %></p>
          
          <!-- КНОПКИ (ТОЛЬКО СВОИ ОТЗЫВЫ) -->
            <form id="form-<%= review.id %>" class="d-none" method="POST" action="/review/edit/<%= review.id %>">
              <textarea name="text" class="form-control mb-2" rows="3"><%= review.text %></textarea>

              <button class="btn btn-sm btn-success">Сохранить</button>

            </form>

          </div>

          <% if (currentUser && currentUser.id === review.userId) { %>
              <div class="d-flex gap-2 flex-shrink-0">

                <!-- РЕДАКТИРОВАТЬ -->
                <button type="button"
                    class="btn btn-sm btn-outline-primary"
                    onclick="editReview('<%= review.id %>')">
                <i class="bi bi-pencil"></i>
              </button>

                <!-- УДАЛИТЬ -->
                <form method="POST" action="/review/delete/<%= review.id %>">
                  <button class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>

              </div>

            <% } %>

          </div>
        <% }) %>
      </div>
      <% } else { %>

        <p class="text-muted">Пока нет отзывов</p>

      <% } %>
</div>
<script src="js/main.js"></script>
<%- include('partials/footer') %>