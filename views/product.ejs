<%- include('partials/header', { title: title || product.name, currentUser: currentUser }) %>

<div class="container mt-5">

  <div class="row">

    <!-- Картинка -->
    <div class="col-md-6">
      <div class="image-wrapper">

        <img src="<%= normalizeImagePath(product.image) %>" class="img-main img-fluid rounded shadow-sm" alt="<%= product.name %>">
        <img src="<%= normalizeImagePath(product.image2) %>" class="img-hover img-fluid rounded shadow-sm" alt="<%= product.name %> - дополнительное фото">

      </div>
    </div>

    <!-- Information -->
    <div class="col-md-6">
      <h2><%= product.name %></h2>
      <% if (product.isNew) { %>
        <div class="alert alert-danger py-1 px-2 d-inline-block">
          ⭐ Новинка
        </div>
      <% } %>

      <% if (product.inStock) { %>
        <div class="alert alert-success py-1 px-2 d-inline-block">
          ✅ В наличии
        </div>
      <% } %>
      <p class="text-muted mb-1">
        <b>Категория:</b> <%= product.category ? product.category.name : '—' %>
      </p>
      <p><%= product.desc %></p>

      <h4 class="mt-3">Цена: <%= product.price %> €</h4>

      <div class="mt-2">

        <% if (!currentUser || currentUser.role !== 'admin') { %>
          <form action="/cart/add" method="post">
            <input type="hidden" name="productId" value="<%= product.id %>">
            <div class="d-flex justify-content-end">
                <button class="btn btn-primary btn-sm">Купить</button>
            </div>
          </form> 
        <% } %>

        <% if (currentUser && currentUser.role === 'admin') { %>
          <div class="mt-2 d-flex gap-2 justify-content-end">
          <a class="btn btn-outline-primary" href="/products/<%= product.id %>/edit">Edit</a>

          <form action="/products/<%= product.id %>/delete" method="post"
                data-confirm
                data-confirm-title="Удалить товар?"
                data-confirm-description="Это действие нельзя отменить. Товар будет удален из каталога."
                data-confirm-text="Удалить"
                data-confirm-cancel-text="Отмена">
            <button class="btn btn-outline-danger">
              Delete
            </button>
          </form>
          </div>
        <% } %>

      </div>

      <!-- REVIEWS -->
      <% if (currentUser) { %>

        <% if (currentUser.role !== 'admin') { %>

          <h4 class="mt-4">Оставить отзыв</h4>

          <% if (reviewErrorMessage) { %>
            <div class="alert alert-warning" role="alert">
              <%= reviewErrorMessage %>
            </div>
          <% } %>

          <form method="POST" action="/review/add">
            <input type="hidden" name="productId" value="<%= product.id %>">

            <div class="mb-3">
              <textarea name="text" class="form-control" rows="3" placeholder="Ваш отзыв..." required></textarea>
            </div>

            <div class="d-flex justify-content-end">
              <button class="btn btn-success">Отправить</button>
            </div>
          </form>

        <% } %>

      <% } else { %>

        <hr>
        <p class="text-muted">
          Чтобы оставить отзыв, <a href="/login" class="no-underline">войдите</a> в аккаунт.
        </p>

      <% } %>

      <div class="d-flex justify-content-end">
        <a href="/catalog" class="btn btn-link no-underline">← Назад в каталог</a>
      </div>

    </div>
  </div>

<!-- ОТЗЫВЫ -->
<div class="mt-3">

  <h4 class="product_h4 mb-4">Отзывы</h4>

  <% if (product.Reviews && product.Reviews.length > 0) { %>

    <div class="d-flex flex-column gap-3">

      <%# Server-side: render product reviews list from `product.Reviews` %>
      <% product.Reviews.forEach(review => { %>

        <!-- REVIEW CARD -->
        <div class="review-card border rounded-4 shadow-sm p-3 position-relative">

          <!-- HEADER -->
          <div class="d-flex justify-content-between align-items-start mb-2">

            <div class="review-header">
              <b><%= review.User.name %></b>

              <small class="text-muted">
                <%= new Intl.DateTimeFormat('ru-RU', {
                  day: '2-digit',
                  month: '2-digit',
                  year: 'numeric'
                }).format(new Date(review.createdAt)) %>
              </small>
            </div>

            <!-- ACTIONS -->
            <% if (currentUser && (currentUser.role === 'admin' || (currentUser.id === review.userId && !review.adminReply))) { %>
              <div class="d-flex gap-2">

                <form method="POST"
                      action="/review/delete/<%= review.id %>"
                      data-confirm
                      data-confirm-title="Удалить отзыв?"
                      data-confirm-description="Это действие нельзя отменить. Отзыв будет удален без возможности восстановления."
                      data-confirm-text="Удалить"
                      data-confirm-cancel-text="Отмена">
                  <button class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-trash"></i>
                  </button>
                </form>

              </div>
            <% } %>

          </div>

          <!-- TEXT -->
          <p id="text-<%= review.id %>" class="review-text mb-2">
            <%= review.text %>
          </p>

          <!-- EDIT FORM -->
          <form id="form-<%= review.id %>"
                class="d-none"
                method="POST"
                action="/review/edit/<%= review.id %>">

            <textarea name="text" class="form-control mb-2"><%= review.text %></textarea>
            <button class="btn btn-sm btn-success">Сохранить</button>

          </form>

          <!-- ADMIN REPLY -->
          <% if (review.adminReply) { %>

            <div class="mt-3 p-3 rounded-4 border-start border-3 border-dark">

              <b class="d-block mb-1">Ответ магазина</b>

              <small class="text-muted d-block mb-2">
                для @<%= review.User.name %>
              </small>

              <p class="mb-0"><%= review.adminReply %></p>

            </div>

          <% } %>

          <!-- ADMIN REPLY FORM -->
          <% if (currentUser && currentUser.role === 'admin' && !review.adminReply) { %>

            <form method="POST"
                  action="/review/reply/<%= review.id %>"
                  class="mt-3">

              <textarea name="adminReply"
                        class="form-control mb-2"
                        rows="2"
                        placeholder="Ответ магазина..."></textarea>

              <button class="btn btn-sm btn-dark">Ответить</button>

            </form>

          <% } %>

        </div>

      <% }) %>

    </div>

  <% } else { %>

    <div class="text-muted">
      Пока нет отзывов — будь первым ✨
    </div>

  <% } %>

</div>

<%- include('partials/footer') %>