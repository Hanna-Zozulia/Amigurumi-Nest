<%- include('partials/header', { title: product.name, currentUser: currentUser }) %>

<div class="container mt-5">

  <div class="row">

    <!-- Картинка -->
    <div class="col-md-6">
      <img src="<%= product.image %>" class="img-fluid rounded shadow-sm" alt="<%= product.name %>">
    </div>

    <!-- Информация -->
    <div class="col-md-6">
      <h2><%= product.name %></h2>

      <p class="text-muted">
        <b>Категория:</b> <%= product.category %>
      </p>

      <p><%= product.desc %></p>

      <h4 class="mt-3">Цена: <%= product.price %> €</h4>

      <div class="mt-4">
        <div class="d-flex justify-content-end">
          <button class="btn btn-primary">Купить</button>
        </div>
          <% if (currentUser && currentUser.role === 'admin') { %>
            <button class="btn btn-outline-primary">Edit</button>
            <button class="btn btn-outline-danger">Delete</button>
          <% } %>
      </div>

      <% if (currentUser) { %>

        <hr>

        <h4>Оставить отзыв</h4>

        <form method="POST" action="/review/add">
          <input type="hidden" name="productId" value="<%= product.id %>">

          <div class="mb-3">
            <textarea name="text" class="form-control" rows="3" placeholder="Ваш отзыв..." required></textarea>
          </div>
          <div class="d-flex justify-content-end">
            <button class="btn btn-success">Отправить</button>
          </div>
        </form>

      <% } else { %>

        <hr>
        <p class="text-muted">
          Чтобы оставить отзыв, <a href="/login">войдите</a> в аккаунт.
        </p>

      <% } %>
      <div class="d-flex justify-content-end">
        <a href="/catalog" class="btn btn-link mt-3">← Назад в каталог</a>
      </div>
    </div>

      <h4 class="product_h4">Отзывы</h4>

      <% if (product.Reviews && product.Reviews.length > 0) { %>

        <% product.Reviews.forEach(r => { %>
          <div class="border rounded p-2 mb-2">
            <b><%= r.User.name %></b>
            <p class="mb-0"><%= r.text %></p>
          </div>
        <% }) %>

      <% } else { %>

        <p class="text-muted">Пока нет отзывов</p>

      <% } %>
</div>

<%- include('partials/footer') %>