<%- include('admin/layout_start', { title: 'Дашборд', currentUser, activeSection: 'dashboard' }) %>

<div class="admin-header">
  <h1><i class="bi bi-house-door"></i> Добро пожаловать</h1>
  <p>Управление сайтом Amigurumi Nest</p>
</div>

<div class="row g-4">
  <div class="col-md-6 col-lg-3">
    <div class="card shadow-sm border-0 h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <div class="text-muted small mb-2">Заказы</div>
            <div class="h3 mb-0"><%= stats.ordersCount %></div>
          </div>
          <div class="admin-stat-icon admin-stat-icon--orders">
            <i class="bi bi-box-seam"></i>
          </div>
        </div>
      </div>
      <a href="/admin/orders" class="card-footer bg-transparent border-top text-decoration-none text-primary small">
        Перейти к заказам <i class="bi bi-arrow-right"></i>
      </a>
    </div>
  </div>

  <div class="col-md-6 col-lg-3">
    <div class="card shadow-sm border-0 h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <div class="text-muted small mb-2">Пользователи</div>
            <div class="h3 mb-0"><%= stats.usersCount %></div>
          </div>
          <div class="admin-stat-icon admin-stat-icon--users">
            <i class="bi bi-people"></i>
          </div>
        </div>
      </div>
      <a href="/admin/users" class="card-footer bg-transparent border-top text-decoration-none text-primary small">
        Управлять пользователями <i class="bi bi-arrow-right"></i>
      </a>
    </div>
  </div>

  <div class="col-md-6 col-lg-3">
    <div class="card shadow-sm border-0 h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <div class="text-muted small mb-2">Продукты</div>
            <div class="h3 mb-0"><%= stats.productsCount %></div>
          </div>
          <div class="admin-stat-icon admin-stat-icon--products">
            <i class="bi bi-shop"></i>
          </div>
        </div>
      </div>
      <a href="/admin/products" class="card-footer bg-transparent border-top text-decoration-none text-primary small">
        Управлять продуктами <i class="bi bi-arrow-right"></i>
      </a>
    </div>
  </div>

  <div class="col-md-6 col-lg-3">
    <div class="card shadow-sm border-0 h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <div class="text-muted small mb-2">Общая сумма заказов</div>
            <div class="h3 mb-0"><%= stats.totalOrdersSum.toFixed(2) %> EUR</div>
          </div>
          <div class="admin-stat-icon admin-stat-icon--revenue">
            <i class="bi bi-currency-euro"></i>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-4 mt-2">
  <div class="col-lg-6">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-white border-bottom">
        <h6 class="mb-0">Недавние заказы</h6>
      </div>
      <div class="card-body p-0">
        <% if (!recentOrders || recentOrders.length === 0) { %>
          <div class="p-3 text-muted small">Пока нет заказов</div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-sm mb-0">
              <tbody>
                <% recentOrders.forEach(order => { %>
                  <tr>
                    <td>
                      <a href="/admin/orders/<%= order.id %>" class="text-decoration-none">
                        Заказ #<%= order.id %>
                      </a>
                    </td>
                    <td><%= order.customerName %></td>
                    <td>
                      <span class="badge <%= order.status === 'unprocessed' ? 'bg-secondary' : order.status === 'processing' ? 'bg-warning text-dark' : 'bg-success' %>">
                        <%= order.statusLabel %>
                      </span>
                    </td>
                    <td class="text-end"><%= order.total.toFixed(2) %> EUR</td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <div class="card-footer bg-white border-top text-center">
            <a href="/admin/orders" class="small text-primary text-decoration-none">Все заказы →</a>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <div class="col-lg-6">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-white border-bottom">
        <h6 class="mb-0">Статистика</h6>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-6">
            <div>
              <div class="text-muted small mb-2">Заказы по статусам</div>
              <div class="admin-stat-list">
                <div class="mb-2">
                  <i class="bi bi-dot-fill admin-stat-dot admin-stat-dot--neutral"></i>
                  <span>Не обработаны:</span> <b><%= stats.ordersStatus.unprocessed %></b>
                </div>
                <div class="mb-2">
                  <i class="bi bi-dot-fill admin-stat-dot admin-stat-dot--warning"></i>
                  <span>В работе:</span> <b><%= stats.ordersStatus.processing %></b>
                </div>
                <div>
                  <i class="bi bi-dot-fill admin-stat-dot admin-stat-dot--success"></i>
                  <span>Отправлены:</span> <b><%= stats.ordersStatus.shipped %></b>
                </div>
              </div>
            </div>
          </div>
          <div class="col-6">
            <div>
              <div class="text-muted small mb-2">Активность пользователей</div>
              <div class="admin-stat-list">
                <div class="mb-2">
                  <i class="bi bi-dot-fill admin-stat-dot admin-stat-dot--success"></i>
                  <span>Активные:</span> <b><%= stats.usersStatus.active %></b>
                </div>
                <div class="mb-2">
                  <i class="bi bi-dot-fill admin-stat-dot admin-stat-dot--warning"></i>
                  <span>Неактивные:</span> <b><%= stats.usersStatus.inactive %></b>
                </div>
                <div>
                  <i class="bi bi-dot-fill admin-stat-dot admin-stat-dot--danger"></i>
                  <span>Заблокированы:</span> <b><%= stats.usersStatus.suspended %></b>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('admin/layout_end', { activeSection }) %>
