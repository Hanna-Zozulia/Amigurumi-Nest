<%- include('partials/header', { title: 'Top 3' }) %>

<div class="container">
    <h1 class="mt-5">Топ 3 самых популярных игрушек на сайте</h1>

    <div class="row">

        <% (products || []).forEach(function(product) { %>
            <div class="col-md-4 top3 mt-4">
                <a href="/product/<%= product.id %>" class="catalog-image-link">
                    <img src="<%= product.image %>" alt="<%= product.name %>">
                    <h2><%= product.name %></h2>
                    <p>Просмотры: <%= product.views %></p>
                </a>
            </div>
        <% }) %>

    </div>
</div>

<%- include('partials/footer') %>