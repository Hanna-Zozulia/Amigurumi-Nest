<%- include('partials/header', { title: 'Каталог', currentUser: currentUser }) %>

<div class="container">

  <div class="d-flex justify-content-between align-items-center mt-5 mb-3">
    <h1 class="m-0">Каталог товаров</h1>

    <% if (currentUser && currentUser.role === 'admin') { %>
      <a href="/products/new" class="btn btn-success">Add product</a>
    <% } %>
  </div>

    <!-- Фильтр -->
     <form method="get" action="/catalog" class="mb-4">
      <div class="input-group">

        <label class="input-group-text">Категория:</label>

        <select class="form-select" name="filter" onchange="this.form.submit()">

          <!-- Все товары -->
          <option value="" <%= !selectedFilter ? 'selected' : '' %>>
            Все категории
          </option>

          <!-- Новинки -->
          <option value="new" <%= selectedFilter === 'new' ? 'selected' : '' %>>
            ⭐ Новинки
          </option>

          <!-- Категории -->
          <% categories.forEach(category => { %>
            <option value="cat-<%= category.id %>"
              <%= selectedFilter === ('cat-' + category.id) ? 'selected' : '' %>>
              <%= category.name %>
            </option>
          <% }) %>

        </select>

      </div>
    </form>

  <!-- Товары -->
  <div class="row g-3">
    <% products.forEach(product => { %>

      <div class="col-12 col-sm-6 col-lg-4">
        <div class="card h-100 shadow-sm">
          <div class="position-relative">

            <% if (product.isNew) { %>
              <span class="position-absolute top-0 start-0 m-2 badge bg-danger px-3 py-2 shadow">
                ✨ Новинка
              </span>
            <% } %>

            <a href="/product/<%= product.id %>" class="catalog-image-link">
              <img src="<%= product.image %>"
                  class="card-img-top catalog-card-img"
                  alt="<%= product.name %>" />
            </a>

          </div>
          
          <div class="card-body d-flex flex-column">
            <h5 class="card-title"><%= product.name %></h5>
            <p class="text-muted mb-1"><b>Категория:</b> <%= product.category?.name %></p>
            <p class="small text-muted flex-grow-1"><b>Описание:</b> <%= product.desc %></p>

            <div class="d-flex justify-content-between align-items-center mt-auto">
              <span class="fw-bold"><%= Number(product.price).toFixed(2) %> €</span>

              <div class="d-flex gap-1">

                <% if (!currentUser || currentUser.role !== 'admin') { %>
                  <form action="/cart/add" method="post">
                    <input type="hidden" name="productId" value="<%= product.id %>">
                    <button class="btn btn-primary btn-sm">Купить</button>
                  </form>
                <% } %>

                <% if (currentUser && currentUser.role === 'admin') { %>
                  <a class="btn btn-outline-primary btn-sm" href="/products/<%= product.id %>/edit">Edit</a>

                  <form action="/products/<%= product.id %>/delete" method="post"
                        data-confirm
                        data-confirm-title="Удалить товар?"
                        data-confirm-description="Это действие нельзя отменить. Товар будет удален из каталога."
                        data-confirm-text="Удалить"
                        data-confirm-cancel-text="Отмена">
                        
                        <input type="hidden" name="redirectTo" value="/catalog">
                    <button class="btn btn-outline-danger btn-sm">
                      Delete
                    </button>
                  </form>
                <% } %>

              </div>
            </div>

          </div>
        </div>
      </div>

    <% }) %>
  </div>

</div>

<%- include('partials/footer') %>