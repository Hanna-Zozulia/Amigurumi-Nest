<%- include('partials/header', { title: 'Восстановление пароля' }) %>

<div class="row justify-content-center login-container">
  <div class="col-sm-10 col-md-6 col-lg-5 mb-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <h1 class="h4 mb-3 text-center">Восстановление пароля</h1>

        <p class="text-muted">
          Укажите email, который вы использовали при регистрации. Мы отправим ссылку для сброса пароля.
        </p>

        <% if (sent) { %>
          <div class="alert alert-info" role="alert">
            Если аккаунт с таким email существует, мы отправили письмо со ссылкой для восстановления.
          </div>
        <% } %>

        <form action="/forgot-password" method="post">
          <div class="mb-3">
            <label for="email" class="form-label">Email</label>
            <input type="email" class="form-control" id="email" name="email" required />
          </div>

          <button type="submit" class="btn btn-primary w-100" data-loading data-loading-text="Отправляем ссылку...">
            Отправить ссылку
          </button>
        </form>

        <p class="text-center mt-3 mb-0">
          <a href="/login">Вернуться ко входу</a>
        </p>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
