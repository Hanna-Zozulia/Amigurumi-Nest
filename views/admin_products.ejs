<%- include('admin/layout_start', { title: 'Продукты', currentUser, activeSection: 'products' }) %>

<div class="admin-header">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h1><i class="bi bi-shop"></i> Продукты</h1>
      <p>Управление каталогом товаров</p>
    </div>
    <a href="/products/new" class="btn btn-primary btn-sm">
      <i class="bi bi-plus-circle"></i> Новый
    </a>
  </div>
</div>

<% if (!products || products.length === 0) { %>
  <div class="alert alert-info text-center">
    <i class="bi bi-inbox"></i> Пока нет продуктов.
    <a href="/products/new" class="alert-link">Добавить первый продукт</a>
  </div>
<% } else { %>
  <div class="row g-4">
    <% products.forEach(product => { %>
      <div class="col-md-6 col-lg-4">
        <div class="card shadow-sm border-0 h-100">
          <% if (product.image) { %>
            <img src="<%= product.image %>" class="card-img-top object-fit-cover admin-product-image" alt="<%= product.name %>">
          <% } else { %>
            <div class="card-img-top bg-light d-flex align-items-center justify-content-center admin-product-placeholder">
              <i class="bi bi-image admin-product-placeholder-icon"></i>
            </div>
          <% } %>
          
          <div class="card-body">
            <h6 class="card-title mb-2"><%= product.name %></h6>
            <p class="card-text text-muted small mb-2"><%= product.category || '—' %></p>
            <p class="h5 mb-3">
              <strong><%= product.price.toFixed(2) %> EUR</strong>
            </p>
            <div class="text-muted small mb-3">
              <i class="bi bi-calendar"></i> <%= product.createdAtFormatted %>
            </div>
          </div>

          <div class="card-footer bg-white border-top">
            <div class="d-grid gap-2">
              <a href="/products/<%= product.id %>/edit" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-pencil"></i> Редактировать
              </a>
              <form method="post" action="/products/<%= product.id %>/delete" class="w-100">
                <button class="btn btn-sm btn-outline-danger w-100" data-loading data-loading-text="Удаляем...">
                  <i class="bi bi-trash"></i> Удалить
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<%- include('admin/layout_end', { activeSection: 'products' }) %>
